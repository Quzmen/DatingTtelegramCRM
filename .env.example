# Скопируйте этот файл в .env, чтобы включить LLM-слой Contact Intelligence.
# Без .env (или с AI_PROVIDER=local) приложение работает полностью локально.

AI_PROVIDER=local
# AI_PROVIDER=gemini

# --- Google Gemini (нужен только если AI_PROVIDER=gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# --- Прокси (если Telegram/Gemini не открываются напрямую — см. README,
# раздел "Работа через прокси/VPN без системного TUN-режима") ---
# TG_PROXY_TYPE=socks5
# TG_PROXY_HOST=127.0.0.1
# TG_PROXY_PORT=1080
# Логин/пароль — только если прокси их требует (например, платный прокси):
# TG_PROXY_USERNAME=
# TG_PROXY_PASSWORD=
# Явное переопределение прокси только для Gemini, если он должен отличаться
# от прокси для Telegram выше (обычно не нужно — по умолчанию использует тот же):
# HTTP_PROXY_URL=socks5://user:pass@127.0.0.1:1080

# Таймаут запроса к Gemini, сек.
AI_LLM_TIMEOUT=20
# Сколько последних сообщений переписки отправлять модели за раз.
AI_LLM_MAX_MESSAGES=60

# Не чаще какого интервала (сек) пересчитывать "живую" оценку интереса
# во время просмотра переписки (всегда только локально, Gemini не трогает).
LIVE_SCORE_MIN_INTERVAL=5
